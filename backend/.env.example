# -----------------------------------------------------------------------------
# 雷犀质检系统 - 环境变量配置模板 (国产大模型适配版)
# -----------------------------------------------------------------------------

# 1. 基础服务与数据库 (保持不变)
PORT=3000
DATABASE_URL="mysql://root:123456@127.0.0.1:3306/ai_quality"
REDIS_HOST="127.0.0.1"
QDRANT_URL="http://127.0.0.1:6333"
MINIO_ENDPOINT="127.0.0.1"

# 2. AI 供应商配置 - [阿里百炼 (DashScope)]
# ---------------------------------------------------------
# API 地址: https://dashscope.aliyuncs.com/compatible-mode/v1
# Embedding 模型: text-embedding-v2 (维度: 1536)
# 聊天模型: qwen-max, qwen-plus
# ---------------------------------------------------------
# AI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# AI_API_KEY="sk-xxxx"
# AI_EMBEDDING_MODEL="text-embedding-v2"
# AI_CHAT_MODEL="qwen-max"
# AI_VECTOR_SIZE=1536

# 3. AI 供应商配置 - [火山引擎 (豆包/Ark)]
# ---------------------------------------------------------
# API 地址: https://ark.cn-beijing.volces.com/api/v3
# 注意：火山引擎的 Model 填的是你的 "推理接入点 ID (Endpoint ID)"
# ---------------------------------------------------------
AI_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
AI_API_KEY="your-volc-api-key"
AI_EMBEDDING_MODEL="ep-xxxxxxxx-xxxx" # 填入你的向量模型接入点
AI_CHAT_MODEL="ep-xxxxxxxx-xxxx"      # 填入你的聊天模型接入点
AI_VECTOR_SIZE=1024 # 豆包向量模型通常为 1024 或 768，请根据实际接入点确认

# 4. 业务逻辑开关
BATCH_QUALITY_CONCURRENCY=5

# 5. AI 请求稳定性配置
# AI_HTTP_TIMEOUT_MS=15000
# AI_HTTP_RETRIES=2

# 6. Redis / 任务锁配置
# BATCH_QUALITY_LOCK_TTL=1800

# 7. MinIO 访问配置
# MINIO_PRESIGNED_TTL=3600
# MINIO_UPLOAD_MAX_SIZE_MB=50
# MINIO_ALLOWED_MIME_TYPES=

# 8. 知识库上传约束
# KNOWLEDGE_UPLOAD_MAX_SIZE_MB=20
# KNOWLEDGE_ALLOWED_MIME_TYPES=text/plain,text/markdown,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document

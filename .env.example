# ======================================
# AiQuality 客服质检系统 - 环境变量示例
# ======================================
# 复制此文件为 .env 并根据实际环境修改配置
# ======================================

# ======================================
# 基础配置
# ======================================
NODE_ENV=development
PORT=3000
JWT_SECRET="your-complex-secret-key"

# ======================================
# 数据库配置 (MySQL)
# ======================================
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=123456
DB_NAME=aiquality

# Prisma 专用连接字符串 (由上述变量组合)
DATABASE_URL="mysql://root:123456@127.0.0.1:3307/aiquality"

# ======================================
# Redis 配置
# ======================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ======================================
# Qdrant 向量数据库配置
# ======================================
QDRANT_URL="http://127.0.0.1:6333"

# ======================================
# MinIO 对象存储配置
# ======================================
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aiquality

# ======================================
# 前端配置
# ======================================
VITE_PORT=5173
VITE_API_BASE_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000
